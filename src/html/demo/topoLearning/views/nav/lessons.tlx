\section{Βασικές ενότητες μαθημάτων}

\paragraph{
Το εκπαιδευτικό υλικό οργανώνεται σε θεματικές ενότητες. Κάθε ενότητα θα περιλαμβάνει μαθήματα, παραδείγματα, ασκήσεις και διαδραστικές δραστηριότητες.
}

\cards{
  columns = 3
  ratio = 1:1

  \item{
    title = Μαθηματικά
    description = Βασικές μαθηματικές έννοιες για γεωμετρία, μετρήσεις, μετασχηματισμούς και υπολογισμούς.
    image = assets/img/lessons_categories/math.png
    url = #math
  }

  \item{
    title = Γεωδαισία
