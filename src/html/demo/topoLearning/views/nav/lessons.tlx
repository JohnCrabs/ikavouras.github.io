    image = assets/img/lessons_categories/gis.png
    url = #gis
  }

  \item{
    title = Όραση Υπολογιστών
    description = Ανάλυση εικόνας, ανίχνευση αντικειμένων, ταξινόμηση και γεωχωρικές εφαρμογές όρασης υπολογιστών.
    image = assets/img/lessons_categories/computer_vision.png
