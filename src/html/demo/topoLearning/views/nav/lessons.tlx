    url = #geodesy
  }

  \item{
    title = Φωτογραμμετρία
    description = Εξαγωγή μετρητικής πληροφορίας από εικόνες, GSD, προσανατολισμός και 3D ανακατασκευή.
    image = assets/img/lessons_categories/photogrammetry.png
    url = #photogrammetry
  }

  \item{
