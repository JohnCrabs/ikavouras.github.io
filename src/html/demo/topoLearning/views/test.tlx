\section{Educational Blocks}

\definition{Ground Sampling Distance}{
The Ground Sampling Distance is the real-world ground distance represented by one image pixel.
}

\example{Simple GSD Calculation}{
If an image has a width of 4000 pixels and a GSD of 0.05 m, then the ground coverage width is 4000 × 0.05 = 200 m.
}

\equation{
GSD = \frac{H \times p}{f}
}

