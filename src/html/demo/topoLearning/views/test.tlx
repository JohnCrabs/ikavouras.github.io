\section{Code}

\code{python}{
import rasterio

with rasterio.open("image.tif") as src:
    print(src.crs)
}

\section{Exercise}

\exercise{Exercise 1}{
Given an image of 6000 × 4000 pixels and GSD = 0.10 m, calculate the ground coverage.
}

\solution{Solution}{
Width: 6000 × 0.10 = 600 m

Height: 4000 × 0.10 = 400 m
}

\section{Quiz}

\quiz{
  question = What does GSD describe?,
  options =
    A: Flight height;
    B: Ground distance represented by one pixel;
    C: Number of images;
    D: Camera model,
  answer = B,
  feedback = GSD describes the real-world ground distance represented by one image pixel.
}

